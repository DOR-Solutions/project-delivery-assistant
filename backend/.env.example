# Server
PORT=5000
NODE_ENV=development

# SQLite database file location (optional; defaults to backend/data/app.db)
# DB_PATH=./data/app.db

# Claude AI (optional). Without a key the assistant runs in offline fallback mode.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
